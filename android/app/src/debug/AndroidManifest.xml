<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only overlay. Permits cleartext traffic so instrumented ViewModel
  tests can talk to a local MockWebServer over http://127.0.0.1. This applies
  ONLY to the debug build type (connectedDebugAndroidTest); the release build
  is TLS-only and unaffected.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:usesCleartextTraffic="true" />
</manifest>
